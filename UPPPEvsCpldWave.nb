Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"releff", "[", "\[Tau]pump_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"tspan", "=", 
        RowBox[{
         RowBox[{"N", "@", "60"}], "\[Tau]pump"}]}], ",", 
       RowBox[{"\[Nu]span", "=", 
        RowBox[{
         RowBox[{"N", "@", " ", "60"}], " ", 
         RowBox[{"TBP", "/", "\[Tau]pump"}]}]}], ",", "\[Nu]res", ",", "tres",
        ",", "total\[Nu]span", ",", "NptsCpldWave", ",", "NptsUPPE"}], "}"}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[Nu]res", "=", 
       RowBox[{"1", "/", "tspan"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"tres", "=", 
       RowBox[{"1", "/", "\[Nu]span"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"NptsCpldWave", "=", 
       SuperscriptBox["2", 
        RowBox[{"Round", "@", 
         RowBox[{"Log", "[", 
          RowBox[{"2", ",", 
           RowBox[{"tspan", "/", "tres"}]}], "]"}]}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"total\[Nu]span", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Nu]pump", "+", 
          RowBox[{"\[Nu]span", "/", "2"}]}], ")"}], "-", 
        RowBox[{"(", 
         RowBox[{"\[Nu]idler", "-", 
          RowBox[{"\[Nu]span", "/", "2"}]}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"NptsUPPE", "=", 
       SuperscriptBox["2", 
        RowBox[{"Round", "@", 
         RowBox[{"Log", "[", 
          RowBox[{"2", ",", 
           RowBox[{"total\[Nu]span", "/", "\[Nu]res"}]}], "]"}]}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"N", "@", "\[Tau]pump"}], "/", "ps"}], ",", 
          RowBox[{"NptsUPPE", " ", 
           RowBox[{
            RowBox[{"Ld", "[", "NptsUPPE", "]"}], "/", "3"}], " ", 
           SuperscriptBox["10", 
            RowBox[{"-", "4"}]]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"N", "@", "\[Tau]pump"}], "/", "ps"}], ",", 
