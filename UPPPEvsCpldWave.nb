Cell["\<\
So, UPPE appears superior for pulses shorter than 100 fs or so, but coupled \
waves are expected to fare much better for ps pulses.\
\>", "Text",
 CellChangeTimes->{{3.9815521334196453`*^9, 
  3.981552205041292*^9}},ExpressionUUID->"85cbefc6-a5d9-5f4f-afa5-\
255c0db88331"],

Cell["\<\
Now let\[CloseCurlyQuote]s modify this a little bit by demanding that we need \
at least a 10 ps time interval to account for group velocity mismatch.\
\>", "Text",
 CellChangeTimes->{{3.981552211529087*^9, 
  3.9815522515194664`*^9}},ExpressionUUID->"ffba5be0-7a6b-294a-adbc-\
192783d5f0d5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"releff2", "[", "\[Tau]pump_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"tspan", "=", 
        RowBox[{"Max", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"N", "@", "60"}], "\[Tau]pump"}], ",", " ", 
          RowBox[{"10", " ", "ps"}]}], "]"}]}], ",", 
       RowBox[{"\[Nu]span", "=", 
        RowBox[{
         RowBox[{"N", "@", " ", "60"}], " ", 
         RowBox[{"TBP", "/", "\[Tau]pump"}]}]}], ",", "\[Nu]res", ",", "tres",
        ",", "total\[Nu]span", ",", "NptsCpldWave", ",", "NptsUPPE"}], "}"}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[Nu]res", "=", 
       RowBox[{"1", "/", "tspan"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"tres", "=", 
       RowBox[{"1", "/", "\[Nu]span"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"NptsCpldWave", "=", 
       SuperscriptBox["2", 
        RowBox[{"Round", "@", 
         RowBox[{"Log", "[", 
          RowBox[{"2", ",", 
           RowBox[{"tspan", "/", "tres"}]}], "]"}]}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"total\[Nu]span", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Nu]pump", "+", 
          RowBox[{"\[Nu]span", "/", "2"}]}], ")"}], "-", 
        RowBox[{"(", 
         RowBox[{"\[Nu]idler", "-", 
          RowBox[{"\[Nu]span", "/", "2"}]}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"NptsUPPE", "=", 
       SuperscriptBox["2", 
        RowBox[{"Round", "@", 
         RowBox[{"Log", "[", 
          RowBox[{"2", ",", 
           RowBox[{"total\[Nu]span", "/", "\[Nu]res"}]}], "]"}]}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"N", "@", "\[Tau]pump"}], "/", "ps"}], ",", 
          RowBox[{"NptsUPPE", " ", 
           RowBox[{
            RowBox[{"Ld", "[", "NptsUPPE", "]"}], "/", "3"}], " ", 
           SuperscriptBox["10", 
            RowBox[{"-", "4"}]]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"N", "@", "\[Tau]pump"}], "/", "ps"}], ",", 
          RowBox[{"3", " ", "NptsCpldWave", " ", 
           RowBox[{
            RowBox[{"Ld", "[", "NptsCpldWave", "]"}], "/", "3"}], " ", 
           SuperscriptBox["10", 
            RowBox[{"-", "4"}]]}]}], "}"}]}], "}"}]}]}], "]"}]}], 
  "\[IndentingNewLine]"}]], "Input",
 CellChangeTimes->{{3.9815491273306427`*^9, 3.981549347379669*^9}, {
  3.9815493817059517`*^9, 3.9815494238877144`*^9}, {3.9815501025067863`*^9, 
  3.9815501087550983`*^9}, {3.981550189009577*^9, 3.98155022636018*^9}, {
  3.9815516920363903`*^9, 3.9815517167062855`*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"d7dd976c-83a9-194f-b01d-fd65b7e119d0"],

Cell[BoxData[
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Tau]x", "=", "1"}], ";", 
    RowBox[{"res", "=", 
     RowBox[{"{", "}"}]}]}], ",", 
   RowBox[{"\[Tau]x", "<=", "4"}], ",", 
   RowBox[{"\[Tau]x", "+=", "0.1"}], ",", 
   RowBox[{"res", "=", 
    RowBox[{"Append", "[", 
     RowBox[{"res", ",", 
      RowBox[{"releff2", "[", 
       RowBox[{
        SuperscriptBox["10", "\[Tau]x"], "fs"}], "]"}]}], "]"}]}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.9815494450714245`*^9, 3.981549544257721*^9}, {
   3.981550400607609*^9, 3.981550401309122*^9}, 3.981551744544422*^9},
