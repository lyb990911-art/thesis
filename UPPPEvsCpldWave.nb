           RowBox[{
            RowBox[{"Ld", "[", "NptsCpldWave", "]"}], "/", "3"}], " ", 
           SuperscriptBox["10", 
            RowBox[{"-", "4"}]]}]}], "}"}]}], "}"}]}]}], "]"}]}], 
